<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvDialogTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Randevu Oluştur"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/etFullName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Randevu Sahibinin Adı Soyadı"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary"
            android:inputType="textPersonName"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="İletişim Numarası"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary"
            android:inputType="phone"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ulaşım Seçimi:"
            android:textSize="16sp"
            android:textColor="?android:attr/textColorPrimary" />

        <RadioGroup
            android:id="@+id/rgDepositStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <RadioButton
                android:id="@+id/rbPaid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Servissiz (190₺)"
                android:textColor="?android:attr/textColorPrimary"
                android:layout_marginEnd="16dp"/>

            <RadioButton
                android:id="@+id/rbUnpaid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Servisli (250₺)"
                android:textColor="?android:attr/textColorPrimary"
                android:checked="true"/>
        </RadioGroup>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorSurfaceVariant"
            android:layout_marginVertical="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Maç Sonrası Ödeme Yapanlar:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp">

            <EditText
                android:id="@+id/etPlayerName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Oyuncu Adı Soyadı"
                android:textColor="?android:attr/textColorPrimary"
                android:textColorHint="?android:attr/textColorSecondary"
                android:inputType="textPersonName"
                android:textSize="14sp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical">

                <CheckBox
                    android:id="@+id/cbCleats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Krampon"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="14sp"/>

                <EditText
                    android:id="@+id/etBuffetExpense"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Büfe (₺)"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textColorHint="?android:attr/textColorSecondary"
                    android:inputType="number"
                    android:layout_marginStart="8dp"
                    android:textSize="14sp"/>

                <Button
                    android:id="@+id/btnAddPlayer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+ Ekle"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="?attr/colorPrimary"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/llPlayersContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp"/>

    </LinearLayout>
</ScrollView>
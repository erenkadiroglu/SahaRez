<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="?attr/colorSurfaceVariant"
        android:elevation="8dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvDateFilter"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tarih Seç"
            android:textSize="25sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:drawableStart="@drawable/ic_calendar"
            android:drawableTint="?attr/colorPrimary"
            android:drawablePadding="12dp"
            android:gravity="center_vertical"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"/>

        <LinearLayout
            android:id="@+id/llLegend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center_vertical">
                <View android:layout_width="12dp" android:layout_height="12dp" android:background="@drawable/shape_circle_red"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="6dp" android:text="DOLU" android:textColor="?android:attr/textColorSecondary" android:textSize="12sp" android:textStyle="bold"/>
            </LinearLayout>
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_marginTop="6dp">
                <View android:layout_width="12dp" android:layout_height="12dp" android:background="@drawable/shape_circle_green"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="6dp" android:text="MÜSAİT" android:textColor="?android:attr/textColorSecondary" android:textSize="12sp" android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvTimeSlots"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:clipToPadding="false"
            android:visibility="visible"/>

        <LinearLayout
            android:id="@+id/layoutAds"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <LinearLayout
                    android:id="@+id/llAdsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"/>
            </ScrollView>
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="?attr/colorSurfaceVariant"
        android:elevation="16dp"
        android:gravity="center">

        <TextView
            android:id="@+id/tvSessions"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="48dp"
            android:text="SEANSLAR"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_edit_text"
            android:backgroundTint="?attr/colorPrimary"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"/>

        <Space android:layout_width="8dp" android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tvAds"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="48dp"
            android:text="İLANLAR"
            android:textSize="14sp"
            android:textColor="?android:attr/textColorSecondary"
            android:background="@drawable/shape_rectangle_border"
            android:backgroundTint="?attr/colorSurface"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"/>

        <Space android:layout_width="8dp" android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tvCall"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="48dp"
            android:text="RANDEVU AL"
            android:textSize="14sp"
            android:textColor="?android:attr/textColorSecondary"
            android:background="@drawable/shape_rectangle_border"
            android:backgroundTint="?attr/colorSurface"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>
</LinearLayout>